{
  "name": "@fishka/seqio",
  "description": "Sequencing file parsers and writers for bioinformatics data",
  "version": "0.4.0",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "private": false,
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf ./dist",
    "lint": "eslint .",
    "format": "prettier --write \"./**/*.{ts,js,md,json}\"",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "release": "npm run lint && npm run test && npm run build && npm publish"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist/**/*",
    "index.ts"
  ],
  "keywords": [
    "abif",
    "ab1",
    "scf",
    "fasta",
    "fastq",
    "chromatogram",
    "sanger",
    "sequencing",
    "bioinformatics"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./abif": {
      "import": {
        "types": "./dist/abif/index.d.mts",
        "default": "./dist/abif/index.mjs"
      },
      "require": {
        "types": "./dist/abif/index.d.ts",
        "default": "./dist/abif/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://gitea.com/fishka/seqio.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
