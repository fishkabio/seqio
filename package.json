{
  "name": "@fishka/seqio",
  "description": "Sequencing I/O — parsers and writers for ABIF/SCF/FASTA/FASTQ and related bioinformatics formats",
  "version": "0.1.0",
  "license": "MIT",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "private": false,
  "sideEffects": false,
  "scripts": {
    "prebuild": "npm run clean",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "clean": "rimraf ./dist",
    "lint": "eslint .",
    "format": "prettier --write \"./**/*.{ts,js,md,json}\"",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "release": "npm run lint && npm run test && npm run build && npm publish"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist/**/*",
    "index.ts"
  ],
  "keywords": [
    "abif",
    "ab1",
    "scf",
    "fasta",
    "fastq",
    "chromatogram",
    "sanger",
    "sequencing",
    "bioinformatics"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./abif": {
      "types": "./dist/esm/src/abif/index.d.ts",
      "import": "./dist/esm/src/abif/index.js",
      "require": "./dist/cjs/src/abif/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://gitea.com/fishka/seqio.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
